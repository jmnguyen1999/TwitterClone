<resources>

    <style name="AppBaseTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/styles.xml, while customizations related to
            backward-compatibility can go here.
        -->
    </style>

    <!-- Application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
        <item name="colorPrimary">@color/appBar_color</item>
    </style>

    <style name="validCount">
        <item name="android:textColor">@color/valid_charLength_color</item>
    </style>

    <style name="invalidCount">
        <item name="android:textColor">@color/invalid_charLength_color</item>
    </style>
</resources>
